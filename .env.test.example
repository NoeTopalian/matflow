# Test environment template. Copy to .env.test and fill in.
#
# CRITICAL: TEST_DATABASE_URL must point at a NEON BRANCH, never the production
# main branch. The setup-test-db.ts guard refuses URLs containing the production
# project endpoint identifier.
#
# How to provision a Neon test branch:
#   1. Visit Neon console -> matflow project -> Branches -> "Create branch"
#      OR install neonctl: `npm i -g neonctl` then
#      `neonctl branches create --project-id <id> --name test`
#   2. Copy the connection string for the new branch (NOT main)
#   3. Paste it below
#   4. Run integration tests: `npx vitest run tests/integration/`
#
# The branch is ephemeral and cheap (~$0.16/hr compute when active).
# Drop it when you're done: `neonctl branches delete test`

TEST_DATABASE_URL=postgresql://user:pass@ep-test-branch-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require
