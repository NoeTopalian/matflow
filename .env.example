# ── Required ──────────────────────────────────────────────────────────────────

# NextAuth secret — generate with: openssl rand -base64 32
# NEVER use the dev value in production
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Database connection
DATABASE_URL="file:./prisma/dev.db"          # SQLite (local dev)
# DATABASE_URL="postgresql://user:pass@host:5432/matflow"  # Postgres (production)

# App URL (required for NextAuth callbacks in production)
NEXTAUTH_URL="https://yourdomain.com"

# Admin bootstrap secret — used only by POST /api/admin/create-tenant
# Generate with: openssl rand -hex 32
MATFLOW_ADMIN_SECRET="replace-with-strong-secret"

# ── Payments (optional — omit to use pay-at-desk mode) ────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Email (optional — required for password reset delivery) ───────────────────
# Configure one of: Resend, SendGrid, Postmark, etc.
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" ONLY in local/staging demo environments.
# When true, hardcoded demo credentials work as a fallback if the DB is unavailable.
# NEVER set to "true" in production.
DEMO_MODE="false"
