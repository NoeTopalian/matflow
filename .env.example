# ── Required ──────────────────────────────────────────────────────────────────

# NextAuth secret — generate with: openssl rand -base64 32
# NEVER use the dev value in production
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Required by TOTP + JWT re-encoding (must match AUTH_SECRET value)
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# DATABASE_URL — Postgres (Neon) connection string.
# For PRODUCTION on Vercel serverless, use the pooled connection with:
#   ?pgbouncer=true&connection_limit=1
# This avoids exhausting Neon's connection pool on burst traffic.
# Example:
#   DATABASE_URL="postgresql://user:pass@host.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# App URL (required for NextAuth callbacks in production)
NEXTAUTH_URL="https://yourdomain.com"

# Admin bootstrap secret — used only by POST /api/admin/create-tenant
# Generate with: openssl rand -hex 32
MATFLOW_ADMIN_SECRET="replace-with-strong-secret"

# ── Payments (optional — omit to use pay-at-desk mode) ────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CLIENT_ID=""

# ── Email (optional — required for password reset delivery) ───────────────────
# Configure one of: Resend, SendGrid, Postmark, etc.
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" ONLY in local/staging demo environments.
# When true, hardcoded demo credentials work as a fallback if the DB is unavailable.
# NEVER set to "true" in production.
DEMO_MODE="false"

# ── Testing mode ──────────────────────────────────────────────────────────────
# When true, bypasses mandatory 2FA (TOTP) enforcement for owners — no
# /login/totp/setup pin, no /login/totp challenge. Schema + TOTP routes are
# untouched, so opt-in 2FA still works for users with totpEnabled=true once
# this flag is off again. Hard-disabled in production (the runtime guard in
# auth.ts logs a warning and ignores the flag when NODE_ENV=production).
TESTING_MODE="false"

# ── Operational toggles ───────────────────────────────────────────────────────
# Global kill switch. Flip to "true" in Vercel env (Settings → Environment
# Variables → save → Redeploy NOT required, env propagates within seconds) to
# return 503 from every route except /api/health, /api/auth/*, and /login.
# Use during incidents, schema migrations that need a quiet window, or
# emergency rollbacks.
MAINTENANCE_MODE="false"

# ── Google OAuth (optional, alternative login) ────────────────────────────────
# Set ENABLE_GOOGLE_OAUTH=true AND populate the client ID + secret to add
# a "Continue with Google" path to the login page. Tenant context comes from
# the signed pendingTenantSlug cookie set at the club-code step — Google
# itself never decides which gym you log into. Email must be verified by
# Google AND match an existing User/Member row in the resolved tenant
# (no auto-provisioning).
#
# To set up: console.cloud.google.com → APIs & Services → Credentials →
# Create OAuth 2.0 Client ID (Web application) → Authorised redirect URIs:
#   https://<your-domain>/api/auth/callback/google
ENABLE_GOOGLE_OAUTH="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Mirror flag for the client bundle so the login page can conditionally
# render the Google button. Must match ENABLE_GOOGLE_OAUTH value.
NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH="false"

# ── Login Notifications (P1.6, optional) ──────────────────────────────────────
# When enabled, every successful sign-in from a not-seen-before fingerprint
# (/24-IP + UA family) emails the account owner with a "Wasn't me?" disown
# link that bumps sessionVersion + locks the account for 1h until password
# reset. Owners can't opt out (server-side override); other accounts can via
# Settings → Account.
#
# Default off so the feature can ship dark and be flipped per-environment.
# Volume estimate: ~10 emails/month for a 100-member gym.
NEXT_PUBLIC_ENABLE_LOGIN_NOTIFICATIONS="false"

# ── Sentry (optional, error monitoring) ───────────────────────────────────────
# Sign up at sentry.io, create a Next.js project, copy the DSN. The same DSN
# goes in both env vars below — Next.js needs the NEXT_PUBLIC_ prefix for the
# browser bundle. Sentry init no-ops when these are unset, so installs without
# a Sentry account stay silent.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
