generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenancy ───────────────────────────────────────────────────────────

model Tenant {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  logoUrl            String?
  logoSize           String    @default("md")
  primaryColor       String    @default("#3b82f6")
  secondaryColor     String    @default("#2563eb")
  textColor          String    @default("#ffffff")
  bgColor            String    @default("#111111")
  fontFamily         String    @default("'Inter', sans-serif")
  customDomain       String?   @unique
  subscriptionStatus  String    @default("trial") // trial, active, suspended, cancelled
  subscriptionTier    String    @default("pro")   // starter, pro, elite, enterprise
  onboardingCompleted Boolean   @default(false)
  onboardingAnswers   Json?
  stripeAccountId     String?
  stripeConnected     Boolean   @default(false)
  stripeAccountStatus Json?     // Fix 3: cached {chargesEnabled, payoutsEnabled, requirementsPastDue, disabledReason, refreshedAt} — see lib/stripe-account-status.ts. Refreshed on account.updated webhook.
  currency            String    @default("GBP")          // Wizard v2: CHECK GBP | EUR | USD (enforced by 20260503000001 migration). Default for new MembershipTier / ClassPack / Payment / Order rows.
  timezone            String    @default("Europe/London") // Wizard v2: IANA TZ; defaults from owner browser at onboarding step 1.
  address             String?                            // Wizard v2: free-text street address for receipts + waivers.
  country             String?                            // Wizard v2: CHECK UK | IE | US | EU | OTHER (enforced by 20260503000001 migration).
  acceptsBacs         Boolean   @default(false)
  memberSelfBilling   Boolean   @default(false)
  billingContactEmail String?
  billingContactUrl   String?
  privacyContactEmail String?
  privacyPolicyUrl    String?
  instagramUrl        String?
  facebookUrl         String?
  tiktokUrl           String?
  youtubeUrl          String?
  twitterUrl          String?
  websiteUrl          String?
  waiverTitle         String?
  waiverContent       String?
  // Kiosk check-in: HMAC-SHA256 hash of the raw kiosk URL token. null = kiosk
  // disabled. Owner can mint / regenerate / disable from settings → integrations.
  // The raw token is shown ONCE and never persisted in cleartext; only the hash
  // is stored at rest, identical to MagicLinkToken / PasswordResetToken pattern.
  kioskTokenHash      String?
  kioskTokenIssuedAt  DateTime?
  // Per-tenant feature-flag overrides; key/value JSON for opt-in betas.
  featureFlags        Json?
  createdAt           DateTime  @default(now())
  deletedAt           DateTime?

  users           User[]
  members         Member[]
  classes         Class[]
  rankSystems     RankSystem[]
  notifications   Notification[]
  announcements   Announcement[]
  membershipTiers MembershipTier[]
}

// ─── Staff / Admin Users ─────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  email          String
  passwordHash   String
  name           String
  role           String   @default("admin") // CHECK: owner | manager | coach | admin (enforced by 20260430000001 migration)
  sessionVersion Int      @default(0)
  totpSecret     String?
  totpEnabled    Boolean  @default(false)
  totpRecoveryCodes Json?  // Wizard v2 / Fix 4 follow-up: array of HMAC-SHA256 hashes (8 codes). Generated post-enrolment in Wizard Step 2; consumed via /api/auth/totp/recover. See lib/recovery-codes.ts.
  failedLoginCount Int    @default(0) // Account lockout: incremented on bcrypt mismatch, reset on success.
  lockedUntil    DateTime? // Account lockout: if in future, login rejects without bcrypt. Cleared on success.
  // P1.6 Login Notifications: opt-out per User. Owners cannot disable
  // (server-side guard in lib/login-event.ts). Default true.
  notifyOnNewLogin Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs       AuditLog[]
  passwordHistory PasswordHistory[]
  classesCoached  Class[]           @relation("ClassCoach")
  loginEvents     LoginEvent[]
  attendanceCheckIns AttendanceRecord[] @relation("AttendanceCheckedInBy")

  @@unique([tenantId, email])
  @@index([lockedUntil])
}

// ─── Members (students) ──────────────────────────────────────────────────────

model Member {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  email          String
  passwordHash   String?
  name           String
  phone          String?
  membershipType String?
  status         String    @default("active") // CHECK: active | inactive | cancelled | taster (enforced by 20260430000001)
  paymentStatus         String    @default("paid")   // CHECK: paid | overdue | paused | free | pending | cancelled (enforced by 20260430000001)
  notes                 String?
  onboardingCompleted   Boolean   @default(false)
  sessionVersion        Int       @default(0)
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  medicalConditions     String?
  dateOfBirth           DateTime?
  accountType           String    @default("adult") // CHECK: adult | junior | kids (enforced by 20260430000001)
  waiverAccepted        Boolean   @default(false)
  waiverAcceptedAt      DateTime?
  waiverIpAddress       String?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  preferredPaymentMethod String   @default("card")
  lastAnnouncementSeenAt DateTime?
  parentMemberId        String?
  parent                Member?   @relation("MemberParent", fields: [parentMemberId], references: [id], onDelete: SetNull)
  children              Member[]  @relation("MemberParent")
  hasKidsHint           Boolean   @default(false)
  failedLoginCount      Int       @default(0) // Account lockout: incremented on bcrypt mismatch, reset on success.
  lockedUntil           DateTime? // Account lockout: if in future, login rejects without bcrypt. Cleared on success.
  // Notification preferences (RB-005). Members opt out per-channel via /member/profile.
  classReminders        Boolean   @default(true)
  beltPromotions        Boolean   @default(true)
  gymAnnouncements      Boolean   @default(true)
  // P1.6 Login Notifications: opt-out per Member. Default true.
  notifyOnNewLogin      Boolean   @default(true)
  joinedAt              DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberRanks   MemberRank[]
  attendances   AttendanceRecord[]
  subscriptions ClassSubscription[]
  waitlists     ClassWaitlist[]
  notifications Notification[]
  signedWaivers SignedWaiver[]
  payments      Payment[]
  classPacks    MemberClassPack[]
  orders        Order[]
  loginEvents   LoginEvent[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([parentMemberId])
  @@index([lockedUntil])
}

// ─── Rank Systems ────────────────────────────────────────────────────────────

model RankSystem {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  discipline String
  name       String
  order      Int
  color      String?
  stripes    Int       @default(0)
  deletedAt  DateTime? // Sprint 5 US-509: soft-delete; consumers default-filter where deletedAt IS NULL

  memberRanks  MemberRank[]
  classes      Class[]              @relation("ClassRequiredRank")
  classMaxes   Class[]              @relation("ClassMaxRank")
  requirements RankRequirement[]

  @@unique([tenantId, discipline, order])
  @@index([tenantId, deletedAt])
}

model MemberRank {
  id           String     @id @default(cuid())
  memberId     String
  member       Member     @relation(fields: [memberId], references: [id])
  rankSystemId String
  rankSystem   RankSystem @relation(fields: [rankSystemId], references: [id])
  stripes      Int        @default(0)
  achievedAt   DateTime   @default(now())
  promotedById String?

  rankHistory RankHistory[]

  @@unique([memberId, rankSystemId])
}

model RankHistory {
  id           String     @id @default(cuid())
  memberRankId String
  memberRank   MemberRank @relation(fields: [memberRankId], references: [id])
  fromRankId   String?
  toRankId     String
  promotedAt   DateTime   @default(now())
  promotedById String?
  notes        String?
}

// Assessment Fix #1: per-rank-system thresholds for "promotion-ready"
// suggestions. A member is a candidate when their attendances since
// MemberRank.achievedAt >= minAttendances AND months elapsed >= minMonths.
// One row per RankSystem; falling back to sensible defaults when missing.
model RankRequirement {
  id              String     @id @default(cuid())
  tenantId        String
  rankSystemId    String     @unique
  rankSystem      RankSystem @relation(fields: [rankSystemId], references: [id])
  minAttendances  Int        @default(30)
  minMonths       Int        @default(6)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([tenantId])
}

// ─── Classes & Scheduling ────────────────────────────────────────────────────

model Class {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  name           String
  description    String?
  instructorId   String?
  coachName      String?
  location       String?
  duration       Int
  maxCapacity    Int?
  requiredRankId String?
  requiredRank   RankSystem? @relation("ClassRequiredRank", fields: [requiredRankId], references: [id])
  maxRankId      String?
  maxRank        RankSystem? @relation("ClassMaxRank", fields: [maxRankId], references: [id])
  coachUserId    String?
  coachUser      User?       @relation("ClassCoach", fields: [coachUserId], references: [id])
  color          String?
  isActive       Boolean     @default(true)
  deletedAt      DateTime?   // Sprint 5 US-509: soft-delete (separate from isActive — isActive=false is "paused", deletedAt is "removed from history")
  createdAt      DateTime    @default(now())

  schedules     ClassSchedule[]
  instances     ClassInstance[]
  subscriptions ClassSubscription[]

  @@index([tenantId, deletedAt])
}

model ClassSchedule {
  id        String    @id @default(cuid())
  classId   String
  class     Class     @relation(fields: [classId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
}

model ClassInstance {
  id                 String   @id @default(cuid())
  classId            String
  class              Class    @relation(fields: [classId], references: [id])
  date               DateTime
  startTime          String
  endTime            String
  isCancelled        Boolean  @default(false)
  cancellationReason String?

  attendances AttendanceRecord[]
  waitlists   ClassWaitlist[]

  @@index([classId, date])
  @@index([date, isCancelled])
}

// ─── Attendance ──────────────────────────────────────────────────────────────

model AttendanceRecord {
  id              String        @id @default(cuid())
  tenantId        String
  memberId        String
  member          Member        @relation(fields: [memberId], references: [id])
  classInstanceId String
  classInstance   ClassInstance @relation(fields: [classInstanceId], references: [id])
  checkInTime     DateTime      @default(now())
  checkInMethod   String        // "qr", "admin", "self", "auto", "kiosk"

  // Which staff user manually checked this member in. null for self / kiosk /
  // auto / pre-existing rows. Populated by /api/checkin POST when method=admin.
  checkedInById   String?
  checkedInByUser User?         @relation("AttendanceCheckedInBy", fields: [checkedInById], references: [id])

  @@unique([memberId, classInstanceId])
  @@index([memberId, checkInTime])
  @@index([tenantId, checkInTime])
  @@index([checkedInById])
}

// ─── Subscriptions & Waitlists ───────────────────────────────────────────────

model ClassSubscription {
  id                   String   @id @default(cuid())
  memberId             String
  member               Member   @relation(fields: [memberId], references: [id])
  classId              String
  class                Class    @relation(fields: [classId], references: [id])
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@unique([memberId, classId])
}

model ClassWaitlist {
  id              String        @id @default(cuid())
  memberId        String
  member          Member        @relation(fields: [memberId], references: [id])
  classInstanceId String
  classInstance   ClassInstance @relation(fields: [classInstanceId], references: [id])
  position        Int
  joinedAt        DateTime      @default(now())
  expiresAt       DateTime?
  status          String        @default("waiting") // waiting, promoted, expired

  @@unique([memberId, classInstanceId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  memberId String?
  member   Member?  @relation(fields: [memberId], references: [id])
  type     String
  channel  String   // "email", "in_app"
  title    String
  message  String
  read     Boolean  @default(false)
  sentAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String
  body      String
  imageUrl  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Password History ────────────────────────────────────────────────────────

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ─── LoginEvent — new-device detection (P1.6 login notifications) ──────────
// One row per (subject, device-fingerprint). userId / memberId are mutually
// exclusive (CHECK constraint enforced in migration). Used to:
//   1. detect when a sign-in comes from a not-seen-before fingerprint, and
//   2. fire a "Wasn't me?" disown link that bumps sessionVersion + locks the
//      account until password reset.
// Fingerprint = HMAC-SHA256(normalisedIp + uaSummary, AUTH_SECRET).
// ipApprox is a /24 (IPv4) or /48 (IPv6) prefix only — coarse and GDPR-safer.
model LoginEvent {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  deviceHash  String                              // HMAC-SHA256(normalisedIp + uaSummary, AUTH_SECRET)
  ipApprox    String?                             // /24 (IPv4) or /48 (IPv6) — coarse, owner-visible
  uaSummary   String?                             // "Chrome 121 on Windows" — derived, lossy
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  disownedAt  DateTime?                           // set by "Wasn't me?" — forces re-notification next time
  createdAt   DateTime  @default(now())

  // Composite uniques per subject — Postgres enforces "one row per (subject, device)"
  // via partial unique indexes on the migration side (one of userId/memberId is always NULL).
  @@unique([userId, deviceHash])
  @@unique([memberId, deviceHash])
  @@index([tenantId, firstSeenAt])
}

// ─── Magic-link tokens (passwordless login + supervised waiver opens) ───────

model MagicLinkToken {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  tokenHash   String    @unique                 // HMAC-SHA256(raw, AUTH_SECRET) — see lib/token-hash.ts
  purpose     String    @default("login")    // login | first_time_signup | waiver_open
  expiresAt   DateTime
  used        Boolean   @default(false)
  usedAt      DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([email, tenantId])
  @@index([expiresAt])
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  tokenHash String   @unique                    // HMAC-SHA256(raw, AUTH_SECRET) — see lib/token-hash.ts
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, tenantId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  tenantId   String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ─── Signed Waivers (immutable acceptance snapshots) ─────────────────────────

model SignedWaiver {
  id              String   @id @default(cuid())
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  tenantId        String
  titleSnapshot   String
  contentSnapshot String
  version         Int      @default(1)
  signerName      String?
  signatureImageUrl String?
  collectedBy       String?  // 'self' | 'admin_device:{userId}'
  ipAddress       String?
  userAgent       String?
  acceptedAt      DateTime @default(now())

  @@index([memberId, acceptedAt])
  @@index([tenantId])
}

// ─── Stripe Webhook Idempotency ──────────────────────────────────────────────

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}

// ─── Rate Limit Hits (DB-backed sliding window) ──────────────────────────────

model RateLimitHit {
  id     String   @id @default(cuid())
  bucket String
  hitAt  DateTime @default(now())

  @@index([bucket, hitAt])
}

// ─── Owner-recorded Initiatives (input for AI causal report) ─────────────────

model Initiative {
  id          String   @id @default(cuid())
  tenantId    String
  type        String                          // marketing | new_class | price_change | holiday | coach_hired | other
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  createdById String
  createdAt   DateTime @default(now())

  attachments InitiativeAttachment[]

  @@index([tenantId, startDate])
}

model InitiativeAttachment {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  blobUrl      String
  filename     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime   @default(now())
}

// ─── Google Drive integration (per-tenant OAuth + indexed folder content) ────

model GoogleDriveConnection {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  folderId        String
  folderName      String
  scope           String    @default("drive.readonly")
  connectedById   String
  connectedAt     DateTime  @default(now())
  lastIndexedAt   DateTime?
}

model IndexedDriveFile {
  id          String   @id @default(cuid())
  tenantId    String
  driveFileId String
  filename    String
  mimeType    String
  modifiedAt  DateTime
  contentHash String
  contentText String?
  indexedAt   DateTime @default(now())

  @@unique([tenantId, driveFileId])
  @@index([tenantId])
}

// ─── Monthly AI causal reports (append-only) ─────────────────────────────────

// ─── CSV import jobs (member migration from competitor systems) ──────────────

model ImportJob {
  id              String   @id @default(cuid())
  tenantId        String
  createdById     String
  source          String                                  // 'generic' | 'mindbody' | 'glofox' | 'wodify'
  fileName        String
  fileBlobUrl     String
  status          String   @default("pending")            // pending | preview | running | complete | failed
  totalRows       Int      @default(0)
  processedRows   Int      @default(0)
  importedRows    Int      @default(0)
  skippedRows     Int      @default(0)
  errorRows       Int      @default(0)
  errorLog        Json?
  dryRunSummary   Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ─── Class packs (prepaid N-classes-for-£X bundles) ──────────────────────────

model ClassPack {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  totalCredits       Int
  validityDays       Int
  pricePence         Int
  currency           String   @default("GBP")
  isActive           Boolean  @default(true)
  stripePriceId      String?
  stripeProductId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  memberPacks MemberClassPack[]

  @@index([tenantId, isActive])
}

model MemberClassPack {
  id                    String    @id @default(cuid())
  tenantId              String
  memberId              String
  member                Member    @relation(fields: [memberId], references: [id])
  packId                String
  pack                  ClassPack @relation(fields: [packId], references: [id])
  creditsRemaining      Int
  purchasedAt           DateTime  @default(now())
  expiresAt             DateTime
  stripePaymentIntentId String?   @unique
  status                String    @default("active") // active | expired | refunded

  redemptions ClassPackRedemption[]

  @@index([memberId, status])
  @@index([tenantId, expiresAt])
}

model ClassPackRedemption {
  id                 String          @id @default(cuid())
  memberPackId       String
  memberPack         MemberClassPack @relation(fields: [memberPackId], references: [id])
  attendanceRecordId String          @unique
  redeemedAt         DateTime        @default(now())

  @@index([memberPackId])
}

// ─── Email log (Resend transactional) ────────────────────────────────────────

model EmailLog {
  id            String   @id @default(cuid())
  tenantId      String
  templateId    String
  recipient     String
  subject       String
  status        String   @default("queued")  // queued | sent | delivered | bounced | failed | complained
  resendId      String?  @unique
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([status])
}

// ─── Payment ledger (mirrors Stripe state, append-only on writes) ─────────────

model Payment {
  id                    String   @id @default(cuid())
  tenantId              String
  memberId              String?
  member                Member?  @relation(fields: [memberId], references: [id])
  stripeInvoiceId       String?  @unique
  stripePaymentIntentId String?  @unique
  stripeChargeId        String?
  amountPence           Int
  currency              String   @default("GBP")
  status                String   // CHECK: succeeded | failed | refunded | disputed | pending (enforced by 20260430000001)
  description           String?
  paidAt                DateTime?
  refundedAt            DateTime?
  refundedAmountPence   Int?
  failureReason         String?
  createdAt             DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([memberId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, paidAt])
}

model Dispute {
  id              String   @id @default(cuid())
  tenantId        String
  paymentId       String?
  stripeDisputeId String   @unique
  amountPence     Int
  currency        String
  reason          String
  status          String   // needs_response | under_review | won | lost | charge_refunded
  evidenceDueAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
}

model MonthlyReport {
  id              String   @id @default(cuid())
  tenantId        String
  periodStart     DateTime
  periodEnd       DateTime
  generationType  String                       // 'auto' | 'on_demand'
  triggeredById   String?
  modelUsed       String
  costPence       Int
  summary         String
  wins            String
  watchOuts       String
  recommendations String
  metricSnapshot  Json
  driveFilesUsed  Json?
  initiativesUsed Json?
  generatedAt     DateTime @default(now())

  @@unique([tenantId, periodStart, generationType])
  @@index([tenantId, periodStart])
}

// ─── Shop orders (LB-001 — pay-at-desk + Stripe checkout persistence) ──────

model Order {
  id              String    @id @default(cuid())
  tenantId        String
  memberId        String?
  member          Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  orderRef        String    @unique // human-friendly reference shown on receipts (e.g. ORD-LMRK4G)
  items           Json      // snapshot of cart at order time: [{id,name,price,quantity}]
  totalPence      Int
  currency        String    @default("GBP")
  status          String    @default("pending") // CHECK: pending | paid | cancelled (enforced by 20260430000005 migration)
  paymentMethod   String    // CHECK: pay_at_desk | stripe (enforced by 20260430000005 migration)
  paidAt          DateTime?
  paidByUserId    String?   // staff user who marked it paid (pay_at_desk only)
  stripeSessionId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([memberId])
}

// ─── Club Store Products (B9 — replaces static lib/products.ts) ─────────────

model Product {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  pricePence Int
  currency   String    @default("GBP")
  category   String    @default("other") // CHECK: clothing | food | drink | equipment | other (enforced by 20260430000003 migration)
  symbol     String?
  description String?
  inStock    Boolean   @default(true)
  deletedAt  DateTime? // Soft-delete; consumers default-filter where deletedAt IS NULL
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, deletedAt])
  @@index([tenantId, inStock, deletedAt])
}

// ─── Gym Applications (B10 — public /apply form persistence) ────────────────

model GymApplication {
  id           String   @id @default(cuid())
  gymName      String
  contactName  String
  email        String
  phone        String?
  discipline   String
  memberCount  String
  notes        String?
  status       String   @default("new") // CHECK: new | contacted | approved | rejected (enforced by 20260430000004 migration)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

// ─── Membership Tiers ────────────────────────────────────────────────────────

model MembershipTier {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  name              String
  description       String?
  pricePence        Int      @default(0)
  currency          String   @default("GBP")
  billingCycle      String   @default("monthly")  // CHECK: monthly | annual | none (enforced by 20260430000001)
  maxClassesPerWeek Int?
  isKids            Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, isActive])
}

// ─── Super-admin (operator) identity ─────────────────────────────────────────
//
// v1 ships with a single shared `MATFLOW_ADMIN_SECRET` cookie — every action is
// stamped with the sentinel `__matflow_super_admin__`. This table is the
// foundation for v1.5 multi-operator (Noe, support staff, etc.) — each row is
// a real operator login with an individual audit trail. UI is deferred; ship
// the table now so v1.5 is purely additive.
model Operator {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  role            String    @default("super_admin") // super_admin | billing_admin | support_admin | read_only
  totpEnabled     Boolean   @default(false)
  totpSecret      String?
  failedLoginCount Int      @default(0)
  lockedUntil     DateTime?
  sessionVersion  Int       @default(0)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?
}

// ─── Platform-level configuration (singleton-style key/value) ────────────────
//
// Holds platform-wide settings: audit-log retention days, feature-flag
// defaults, webhook outboxes (Slack / email destinations for operator alerts).
model PlatformConfig {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}
