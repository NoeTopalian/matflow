generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenancy ───────────────────────────────────────────────────────────

model Tenant {
  id                     String    @id @default(cuid())
  name                   String
  slug                   String    @unique
  logoUrl                String?
  logoSize               String    @default("md")
  primaryColor           String    @default("#3b82f6")
  secondaryColor         String    @default("#2563eb")
  textColor              String    @default("#ffffff")
  bgColor                String    @default("#111111")
  fontFamily             String    @default("'Inter', sans-serif")
  customDomain           String?   @unique
  subscriptionStatus     String    @default("trial") // trial, active, suspended, cancelled
  subscriptionTier       String    @default("pro") // starter, pro, elite, enterprise
  onboardingCompleted    Boolean   @default(false)
  onboardingAnswers      Json?
  stripeAccountId        String?
  stripeConnected        Boolean   @default(false)
  stripeAccountStatus    Json? // Fix 3: cached {chargesEnabled, payoutsEnabled, requirementsPastDue, disabledReason, refreshedAt} — see lib/stripe-account-status.ts. Refreshed on account.updated webhook.
  currency               String    @default("GBP") // Wizard v2: CHECK GBP | EUR | USD (enforced by 20260503000001 migration). Default for new MembershipTier / ClassPack / Payment / Order rows.
  timezone               String    @default("Europe/London") // Wizard v2: IANA TZ; defaults from owner browser at onboarding step 1.
  address                String? // Wizard v2: free-text street address for receipts + waivers.
  country                String? // Wizard v2: CHECK UK | IE | US | EU | OTHER (enforced by 20260503000001 migration).
  checkinWindowBeforeMin Int       @default(30) // CHECK: 0-180 (enforced by migration 20260513000003)
  checkinWindowAfterMin  Int       @default(30) // CHECK: 0-180 (enforced by migration 20260513000003)
  acceptsBacs            Boolean   @default(false)
  memberSelfBilling      Boolean   @default(false)
  billingContactEmail    String?
  billingContactUrl      String?
  privacyContactEmail    String?
  privacyPolicyUrl       String?
  instagramUrl           String?
  facebookUrl            String?
  tiktokUrl              String?
  youtubeUrl             String?
  twitterUrl             String?
  websiteUrl             String?
  // Sub-project #5 (2026-05-09): WhatsApp / Telegram / Discord group invite URL.
  // Shown alongside other socials in the member-portal gym card.
  groupChatUrl           String?
  waiverTitle            String?
  waiverContent          String?
  kidsWaiverTitle        String?
  kidsWaiverContent      String?
  // Kiosk check-in: HMAC-SHA256 hash of the raw kiosk URL token. null = kiosk
  // disabled. Owner can mint / regenerate / disable from settings → integrations.
  // The raw token is shown ONCE and never persisted in cleartext; only the hash
  // is stored at rest, identical to MagicLinkToken / PasswordResetToken pattern.
  kioskTokenHash         String?
  kioskTokenIssuedAt     DateTime?
  // Per-tenant feature-flag overrides; key/value JSON for opt-in betas.
  featureFlags           Json?
  createdAt              DateTime  @default(now())
  deletedAt              DateTime?

  users             User[]
  members           Member[]
  classes           Class[]
  rankSystems       RankSystem[]
  notifications     Notification[]
  announcements     Announcement[]
  membershipTiers   MembershipTier[]
  classRosters      ClassRoster[]
  tasks             Task[]
  memberPhotos      MemberPhoto[]
  pushSubscriptions PushSubscription[]
}

// ─── Staff / Admin Users ─────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  email             String
  passwordHash      String
  name              String
  role              String    @default("admin") // CHECK: owner | manager | coach | admin (enforced by 20260430000001 migration)
  sessionVersion    Int       @default(0)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  totpRecoveryCodes Json? // Wizard v2 / Fix 4 follow-up: array of HMAC-SHA256 hashes (8 codes). Generated post-enrolment in Wizard Step 2; consumed via /api/auth/totp/recover. See lib/recovery-codes.ts.
  failedLoginCount  Int       @default(0) // Account lockout: incremented on bcrypt mismatch, reset on success.
  lockedUntil       DateTime? // Account lockout: if in future, login rejects without bcrypt. Cleared on success.
  // P1.6 Login Notifications: opt-out per User. Owners cannot disable
  // (server-side guard in lib/login-event.ts). Default true.
  notifyOnNewLogin  Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  auditLogs          AuditLog[]
  passwordHistory    PasswordHistory[]
  classesCoached     Class[]            @relation("ClassCoach")
  loginEvents        LoginEvent[]
  attendanceCheckIns AttendanceRecord[] @relation("AttendanceCheckedInBy")
  classRosterAdds    ClassRoster[]      @relation("ClassRosterAddedBy")
  pushSubscriptions  PushSubscription[]
  tasksCreated       Task[]             @relation("TaskCreatedBy")
  tasksAssigned      Task[]             @relation("TaskAssignedTo")
  // feat/member-tickable-notes Phase 4: completedById tracks WHO ticked a
  // task — could be the assignee themselves OR an owner overriding on
  // behalf of someone else. Always a User, never a Member (member-side
  // completion path resolves the member's User row before stamping).
  tasksCompleted     Task[]             @relation("TaskCompletedBy")

  @@unique([tenantId, email])
  @@index([lockedUntil])
}

// ─── Members (students) ──────────────────────────────────────────────────────

model Member {
  id                       String    @id @default(cuid())
  tenantId                 String
  tenant                   Tenant    @relation(fields: [tenantId], references: [id])
  email                    String
  passwordHash             String?
  name                     String
  phone                    String?
  membershipType           String?
  status                   String    @default("active") // CHECK: active | inactive | cancelled | taster (enforced by 20260430000001)
  paymentStatus            String    @default("paid") // CHECK: paid | overdue | paused | free | pending | cancelled (enforced by 20260430000001)
  notes                    String?
  onboardingCompleted      Boolean   @default(false)
  sessionVersion           Int       @default(0)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  medicalConditions        String?
  dateOfBirth              DateTime?
  accountType              String    @default("adult") // CHECK: adult | junior | kids | parent (enforced by 20260430000001 + 20260512000001)
  waiverAccepted           Boolean   @default(false)
  waiverAcceptedAt         DateTime?
  waiverIpAddress          String?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  preferredPaymentMethod   String    @default("card")
  lastAnnouncementSeenAt   DateTime?
  parentMemberId           String?
  parent                   Member?   @relation("MemberParent", fields: [parentMemberId], references: [id], onDelete: SetNull)
  children                 Member[]  @relation("MemberParent")
  hasKidsHint              Boolean   @default(false)
  failedLoginCount         Int       @default(0) // Account lockout: incremented on bcrypt mismatch, reset on success.
  lockedUntil              DateTime? // Account lockout: if in future, login rejects without bcrypt. Cleared on success.
  // Optional TOTP for password-bearing members (mirrors User shape). Kids + magic-link-only members never enrol.
  // Once totpEnabled=true the member cannot self-disable; only operator (admin.member.totp_reset) or
  // gym staff (member.totp_reset) can clear via dedicated reset endpoints.
  totpEnabled              Boolean   @default(false)
  totpSecret               String?
  totpRecoveryCodes        Json?
  // Notification preferences (RB-005). Members opt out per-channel via /member/profile.
  classReminders           Boolean   @default(true)
  beltPromotions           Boolean   @default(true)
  gymAnnouncements         Boolean   @default(true)
  // P1.6 Login Notifications: opt-out per Member. Default true.
  notifyOnNewLogin         Boolean   @default(true)
  // feat/member-tickable-notes Phase 5: per-member opt-out for "your gym sent
  // you an action" emails + push. Default true — staff need a working channel
  // for waivers, payment retries, gear pickups. Members can disable on
  // /member/profile if they only want to use the in-app list.
  taskAssignments          Boolean   @default(true)
  joinedAt                 DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  memberRanks       MemberRank[]
  attendances       AttendanceRecord[]
  subscriptions     ClassSubscription[]
  waitlists         ClassWaitlist[]
  notifications     Notification[]
  signedWaivers     SignedWaiver[]
  payments          Payment[]
  classPacks        MemberClassPack[]
  orders            Order[]
  loginEvents       LoginEvent[]
  classRosters      ClassRoster[]
  // US-5: photo evidence + milestone uploads. CASCADE on member delete so
  // lib/member-delete.ts sweeps them automatically. uploadedByMember is the
  // reverse relation for MemberPhoto.uploadedByMemberId (SET NULL).
  photos            MemberPhoto[]       @relation("MemberPhotoSubject")
  uploadedPhotos    MemberPhoto[]       @relation("MemberPhotoUploader")
  pushSubscriptions PushSubscription[]
  // feat/member-tickable-notes Phase 4: tickable notes addressed to this
  // member by gym staff. SET NULL on member delete preserves task history
  // for the staff dashboard's "sent items" view (mirrors Task.assignedTo).
  tasksAssigned     Task[]              @relation("TaskAssigneeMember")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([parentMemberId])
  @@index([lockedUntil])
  @@index([tenantId, joinedAt])
  // Audit iter-1-member-lifecycle A3H-10: every Stripe webhook event resolves
  // the member by (stripeCustomerId) inside the tenant. Without this index
  // Postgres seq-scans the Member table on every webhook event — ~50ms at 5k
  // members, approaches Stripe's timeout on the 7-trip invoice.payment_failed
  // path under sustained load.
  @@index([tenantId, stripeCustomerId])
  // Speculative for future direct-subscription lookups (M3A-2 backlog item).
  @@index([stripeSubscriptionId])
  // Dashboard overdue + future dunning queries. (M3A-1 backlog item.)
  @@index([tenantId, paymentStatus])
  // Lane 1 iter-1 P-02 [Critical]: covering index for the /dashboard/members
  // SSR fetch (orderBy: name asc). Migration 20260606200000.
  @@index([tenantId, name])
}

// ─── Push Subscriptions (PWA web-push) ───────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  memberId  String?
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([memberId])
  @@index([userId])
}

// ─── Member photos (US-5: kid evidence + milestones) ─────────────────────────
//
// Parent-uploaded photos of their kid (training-evidence, belt promotion
// snapshots, etc.). Visible to the parent + staff in the same tenant; never
// browseable across families.
model MemberPhoto {
  id                 String      @id @default(cuid())
  tenantId           String
  tenant             Tenant      @relation(fields: [tenantId], references: [id])
  memberId           String
  member             Member      @relation("MemberPhotoSubject", fields: [memberId], references: [id], onDelete: Cascade)
  url                String // Accepts both blob URLs and data: URLs (upload route caps at 2MB)
  caption            String?
  // feat/member-profile-pictures Track A Phase A2: 'profile' joins the kind
  // enum. There is at most one row per (memberId, kind='profile') — enforced
  // by partial unique index in migration 20260606100000. A PUT to the
  // profile-picture route uses upsert semantics: the row replaces in place.
  kind               String      @default("evidence") // CHECK: evidence | milestone | promotion | profile (enforced by migrations 20260513000001, 20260606100000)
  uploadedAt         DateTime    @default(now())
  uploadedByMemberId String?
  uploadedByMember   Member?     @relation("MemberPhotoUploader", fields: [uploadedByMemberId], references: [id], onDelete: SetNull)
  memberRankId       String?
  memberRank         MemberRank? @relation(fields: [memberRankId], references: [id], onDelete: SetNull)

  @@index([memberId, uploadedAt])
  @@index([tenantId])
  @@index([memberRankId])
}

// ─── Rank Systems ────────────────────────────────────────────────────────────

model RankSystem {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  discipline String
  name       String
  order      Int
  color      String?
  stripes    Int       @default(0)
  deletedAt  DateTime? // Sprint 5 US-509: soft-delete; consumers default-filter where deletedAt IS NULL

  memberRanks  MemberRank[]
  classes      Class[]           @relation("ClassRequiredRank")
  classMaxes   Class[]           @relation("ClassMaxRank")
  requirements RankRequirement[]

  @@unique([tenantId, discipline, order])
  @@index([tenantId, deletedAt])
}

model MemberRank {
  id           String     @id @default(cuid())
  memberId     String
  member       Member     @relation(fields: [memberId], references: [id])
  rankSystemId String
  rankSystem   RankSystem @relation(fields: [rankSystemId], references: [id])
  stripes      Int        @default(0)
  achievedAt   DateTime   @default(now())
  promotedById String?

  rankHistory RankHistory[]
  photos      MemberPhoto[]

  @@unique([memberId, rankSystemId])
}

model RankHistory {
  id           String     @id @default(cuid())
  memberRankId String
  memberRank   MemberRank @relation(fields: [memberRankId], references: [id])
  fromRankId   String?
  toRankId     String
  promotedAt   DateTime   @default(now())
  promotedById String?
  notes        String?

  // Audit iter-2-member-surface A5I2-P-1: backs GET /api/member/me/recent-demotion
  // and the staff promotion-history view. Was a full table scan before; matters
  // once we cross ~500 members × ~5 rank events.
  @@index([memberRankId])
  @@index([promotedAt])
}

// Assessment Fix #1: per-rank-system thresholds for "promotion-ready"
// suggestions. A member is a candidate when their attendances since
// MemberRank.achievedAt >= minAttendances AND months elapsed >= minMonths.
// One row per RankSystem; falling back to sensible defaults when missing.
model RankRequirement {
  id             String     @id @default(cuid())
  tenantId       String
  rankSystemId   String     @unique
  rankSystem     RankSystem @relation(fields: [rankSystemId], references: [id])
  minAttendances Int        @default(30)
  minMonths      Int        @default(6)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([tenantId])
}

// ─── Classes & Scheduling ────────────────────────────────────────────────────

model Class {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  name           String
  description    String?
  instructorId   String?
  coachName      String?
  location       String?
  duration       Int
  maxCapacity    Int?
  requiredRankId String?
  requiredRank   RankSystem? @relation("ClassRequiredRank", fields: [requiredRankId], references: [id])
  maxRankId      String?
  maxRank        RankSystem? @relation("ClassMaxRank", fields: [maxRankId], references: [id])
  coachUserId    String?
  // Audit iter-1-operator-admin A6I1-V-1 (H2-4): `onDelete: SetNull` so
  // deleting a staff user does not hit a Prisma P2003 FK RESTRICT. The
  // class survives and just becomes unassigned — owner can assign a new
  // coach via the dashboard.
  coachUser      User?       @relation("ClassCoach", fields: [coachUserId], references: [id], onDelete: SetNull)
  color          String?
  isActive       Boolean     @default(true)
  deletedAt      DateTime? // Sprint 5 US-509: soft-delete (separate from isActive — isActive=false is "paused", deletedAt is "removed from history")
  createdAt      DateTime    @default(now())

  schedules     ClassSchedule[]
  instances     ClassInstance[]
  subscriptions ClassSubscription[]
  rosterMembers ClassRoster[]

  @@index([tenantId, deletedAt])
}

model ClassSchedule {
  id        String    @id @default(cuid())
  classId   String
  class     Class     @relation(fields: [classId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
}

model ClassInstance {
  id                 String   @id @default(cuid())
  classId            String
  class              Class    @relation(fields: [classId], references: [id])
  date               DateTime
  startTime          String
  endTime            String
  isCancelled        Boolean  @default(false)
  cancellationReason String?

  attendances AttendanceRecord[]
  waitlists   ClassWaitlist[]

  @@index([classId, date])
  @@index([date, isCancelled])
}

// ─── Attendance ──────────────────────────────────────────────────────────────

model AttendanceRecord {
  id              String        @id @default(cuid())
  tenantId        String
  memberId        String
  member          Member        @relation(fields: [memberId], references: [id])
  classInstanceId String
  classInstance   ClassInstance @relation(fields: [classInstanceId], references: [id])
  checkInTime     DateTime      @default(now())
  checkInMethod   String // "qr", "admin", "self", "auto", "kiosk"

  // Which staff user manually checked this member in. null for self / kiosk /
  // auto / pre-existing rows. Populated by /api/checkin POST when method=admin.
  // Audit iter-1-operator-admin A6I1-V-1: `onDelete: SetNull` so deleting
  // a staff user does not hit a Prisma P2003 FK RESTRICT. Field is already
  // nullable (kiosk/auto check-ins) so SetNull is semantically correct.
  checkedInById   String?
  checkedInByUser User?   @relation("AttendanceCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)

  @@unique([memberId, classInstanceId])
  @@index([memberId, checkInTime])
  @@index([tenantId, checkInTime])
  @@index([checkedInById])
}

// ─── Subscriptions & Waitlists ───────────────────────────────────────────────

model ClassSubscription {
  id                   String   @id @default(cuid())
  memberId             String
  member               Member   @relation(fields: [memberId], references: [id])
  classId              String
  class                Class    @relation(fields: [classId], references: [id])
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@unique([memberId, classId])
  // Audit iter-1-database A8I1-P-12: notification fan-out on class
  // cancellation must fetch all subscribers by classId. The unique above
  // serves memberId-leading queries only.
  @@index([classId])
}

model ClassRoster {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  classId       String
  class         Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  addedAt       DateTime @default(now())
  addedByUserId String?
  addedByUser   User?    @relation("ClassRosterAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([classId, memberId])
  @@index([tenantId, classId])
  @@index([tenantId, memberId])
}

model ClassWaitlist {
  id              String        @id @default(cuid())
  memberId        String
  member          Member        @relation(fields: [memberId], references: [id])
  classInstanceId String
  classInstance   ClassInstance @relation(fields: [classInstanceId], references: [id])
  position        Int
  joinedAt        DateTime      @default(now())
  expiresAt       DateTime?
  status          String        @default("waiting") // waiting, promoted, expired

  @@unique([memberId, classInstanceId])
  // Audit iter-1-database A8I1-P-9: coach register + waitlist promotion
  // logic both filter by classInstanceId without a leading memberId.
  @@index([classInstanceId])
  @@index([classInstanceId, status])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  memberId String?
  member   Member?  @relation(fields: [memberId], references: [id])
  type     String
  channel  String // "email", "in_app"
  title    String
  message  String
  read     Boolean  @default(false)
  sentAt   DateTime @default(now())

  @@index([tenantId, sentAt])
  @@index([tenantId, memberId, read])
}

model Announcement {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String
  body      String
  imageUrl  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, pinned, createdAt])
}

// ─── Password History ────────────────────────────────────────────────────────

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  // Audit iter-1-database A8I1-V-4 [High]: cascade — password history has
  // no meaning without the user; deleting the user should sweep the rows.
  // The prior default RESTRICT caused silent P2003 500s on staff delete.
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ─── LoginEvent — new-device detection (P1.6 login notifications) ──────────
// One row per (subject, device-fingerprint). userId / memberId are mutually
// exclusive (CHECK constraint enforced in migration). Used to:
//   1. detect when a sign-in comes from a not-seen-before fingerprint, and
//   2. fire a "Wasn't me?" disown link that bumps sessionVersion + locks the
//      account until password reset.
// Fingerprint = HMAC-SHA256(normalisedIp + uaSummary, AUTH_SECRET).
// ipApprox is a /24 (IPv4) or /48 (IPv6) prefix only — coarse and GDPR-safer.
model LoginEvent {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberId    String?
  member      Member?   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  deviceHash  String // HMAC-SHA256(normalisedIp + uaSummary, AUTH_SECRET)
  ipApprox    String? // /24 (IPv4) or /48 (IPv6) — coarse, owner-visible
  uaSummary   String? // "Chrome 121 on Windows" — derived, lossy
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  disownedAt  DateTime? // set by "Wasn't me?" — forces re-notification next time
  createdAt   DateTime  @default(now())

  // Composite uniques per subject — Postgres enforces "one row per (subject, device)"
  // via partial unique indexes on the migration side (one of userId/memberId is always NULL).
  @@unique([userId, deviceHash])
  @@unique([memberId, deviceHash])
  @@index([tenantId, firstSeenAt])
}

// ─── Magic-link tokens (passwordless login + supervised waiver opens) ───────

model MagicLinkToken {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  tokenHash String    @unique // HMAC-SHA256(raw, AUTH_SECRET) — see lib/token-hash.ts
  purpose   String    @default("login") // login | first_time_signup | waiver_open
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([email, tenantId])
  @@index([expiresAt])
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  tokenHash String   @unique // HMAC-SHA256(raw, AUTH_SECRET) — see lib/token-hash.ts
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, tenantId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  // Audit iter-1-operator-admin A6I1-V-1 (H2-4 deferred Critical):
  // `onDelete: SetNull` so deleting a staff User does not hit a Prisma P2003
  // FK RESTRICT. Without it, the staff DELETE route silently returns 500 for
  // any staff who ever performed an audited action. `userId` was already
  // nullable, so SetNull is semantically correct (the audit row keeps the
  // record of the action, just loses the user attribution).
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Audit iter-1-operator-admin A6I1-V-4: nullable to support platform-
  // level events that don't belong to a tenant yet (e.g. rejecting a gym
  // application before tenant creation). RLS policy
  // `tenantId = current_setting('app.current_tenant_id')` returns NULL for
  // null-tenant rows, so they are invisible to tenant-scoped queries — only
  // reachable via `withRlsBypass`. Operator-admin surfaces use that path.
  tenantId   String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  // Audit iter-1-operator-admin A6I1-P-4: backs the dashboard's
  // `findMany({ orderBy: { createdAt: "desc" }, take: 10 })` cross-tenant
  // scan. Without a standalone `createdAt` index Postgres has to sort the
  // full heap.
  @@index([createdAt])
}

// ─── Signed Waivers (immutable acceptance snapshots) ─────────────────────────

model SignedWaiver {
  id                String   @id @default(cuid())
  memberId          String
  member            Member   @relation(fields: [memberId], references: [id])
  tenantId          String
  titleSnapshot     String
  contentSnapshot   String
  version           Int      @default(1)
  signerName        String?
  signatureImageUrl String?
  collectedBy       String? // 'self' | 'admin_device:{userId}'
  ipAddress         String?
  userAgent         String?
  acceptedAt        DateTime @default(now())

  @@index([memberId, acceptedAt])
  @@index([tenantId])
  @@index([tenantId, acceptedAt])
}

// ─── Stripe Webhook Idempotency ──────────────────────────────────────────────

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}

// ─── Rate Limit Hits (DB-backed sliding window) ──────────────────────────────

model RateLimitHit {
  id     String   @id @default(cuid())
  bucket String
  hitAt  DateTime @default(now())

  @@index([bucket, hitAt])
}

// ─── Owner-recorded Initiatives (input for AI causal report) ─────────────────

model Initiative {
  id          String    @id @default(cuid())
  tenantId    String
  type        String // marketing | new_class | price_change | holiday | coach_hired | other
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  createdById String
  createdAt   DateTime  @default(now())

  attachments InitiativeAttachment[]

  @@index([tenantId, startDate])
}

model InitiativeAttachment {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  blobUrl      String
  filename     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime   @default(now())
}

// ─── Google Drive integration (per-tenant OAuth + indexed folder content) ────

model GoogleDriveConnection {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  folderId      String
  folderName    String
  scope         String    @default("drive.readonly")
  connectedById String
  connectedAt   DateTime  @default(now())
  lastIndexedAt DateTime?
}

model IndexedDriveFile {
  id          String   @id @default(cuid())
  tenantId    String
  driveFileId String
  filename    String
  mimeType    String
  modifiedAt  DateTime
  contentHash String
  contentText String?
  indexedAt   DateTime @default(now())

  @@unique([tenantId, driveFileId])
  @@index([tenantId])
}

// ─── Monthly AI causal reports (append-only) ─────────────────────────────────

// ─── CSV import jobs (member migration from competitor systems) ──────────────

model ImportJob {
  id            String    @id @default(cuid())
  tenantId      String
  createdById   String
  source        String // 'generic' | 'mindbody' | 'glofox' | 'wodify'
  fileName      String
  fileBlobUrl   String
  status        String    @default("pending") // pending | preview | running | complete | failed
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  importedRows  Int       @default(0)
  skippedRows   Int       @default(0)
  errorRows     Int       @default(0)
  errorLog      Json?
  dryRunSummary Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId, createdAt])
}

// ─── Class packs (prepaid N-classes-for-£X bundles) ──────────────────────────

model ClassPack {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  totalCredits    Int
  validityDays    Int
  pricePence      Int
  currency        String   @default("GBP")
  isActive        Boolean  @default(true)
  stripePriceId   String?
  stripeProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberPacks MemberClassPack[]

  @@index([tenantId, isActive])
}

model MemberClassPack {
  id                    String    @id @default(cuid())
  tenantId              String
  memberId              String
  member                Member    @relation(fields: [memberId], references: [id])
  packId                String
  pack                  ClassPack @relation(fields: [packId], references: [id])
  creditsRemaining      Int
  purchasedAt           DateTime  @default(now())
  expiresAt             DateTime
  stripePaymentIntentId String?   @unique
  status                String    @default("active") // active | expired | refunded

  redemptions ClassPackRedemption[]

  @@index([memberId, status])
  @@index([tenantId, expiresAt])
}

model ClassPackRedemption {
  id                 String          @id @default(cuid())
  memberPackId       String
  memberPack         MemberClassPack @relation(fields: [memberPackId], references: [id])
  attendanceRecordId String          @unique
  redeemedAt         DateTime        @default(now())

  @@index([memberPackId])
}

// ─── Email log (Resend transactional) ────────────────────────────────────────

model EmailLog {
  id           String    @id @default(cuid())
  tenantId     String
  templateId   String
  recipient    String
  subject      String
  status       String    @default("queued") // queued | sent | delivered | bounced | failed | complained
  resendId     String?   @unique
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([status])
  // Audit iter-1-database A8I1-V-3 / A8I1-P-3 (closes deferred A7I1-P-4):
  // backs lib/email.ts bounce-check findFirst on
  //   { tenantId, recipient, status: in [bounced, complained], createdAt: gte }
  // fired before EVERY outbound send. Without this composite Postgres
  // scans the full 30-day tenant window per email.
  @@index([tenantId, recipient, status, createdAt])
}

// ─── Payment ledger (mirrors Stripe state, append-only on writes) ─────────────

model Payment {
  id                    String    @id @default(cuid())
  tenantId              String
  memberId              String?
  member                Member?   @relation(fields: [memberId], references: [id])
  stripeInvoiceId       String?   @unique
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?
  amountPence           Int
  currency              String    @default("GBP")
  status                String // CHECK: succeeded | failed | refunded | disputed | pending (enforced by 20260430000001)
  description           String?
  paidAt                DateTime?
  refundedAt            DateTime?
  refundedAmountPence   Int?
  failureReason         String?
  createdAt             DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([memberId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, paidAt])
  // Audit iter-1-operator-admin A6I1-P-3: backs admin cross-tenant aggregates
  // (dashboard 7-day failed-payment count, billing 30-day gross revenue).
  // The tenant-leading indexes above are useless without a tenantId in the
  // filter — Postgres seq-scans the full Payment table on every admin nav.
  @@index([status, createdAt])
  @@index([status, paidAt])
}

model Dispute {
  id              String    @id @default(cuid())
  tenantId        String
  paymentId       String?
  stripeDisputeId String    @unique
  amountPence     Int
  currency        String
  reason          String
  status          String // needs_response | under_review | won | lost | charge_refunded
  evidenceDueAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  // Audit iter-1-operator-admin A6I1-P-3: backs admin billing page's
  // cross-tenant open/lost dispute aggregates.
  @@index([status, updatedAt])
}

model MonthlyReport {
  id              String   @id @default(cuid())
  tenantId        String
  periodStart     DateTime
  periodEnd       DateTime
  generationType  String // 'auto' | 'on_demand'
  triggeredById   String?
  modelUsed       String
  costPence       Int
  summary         String
  wins            String
  watchOuts       String
  recommendations String
  metricSnapshot  Json
  driveFilesUsed  Json?
  initiativesUsed Json?
  generatedAt     DateTime @default(now())

  @@unique([tenantId, periodStart, generationType])
  @@index([tenantId, periodStart])
}

// ─── Shop orders (LB-001 — pay-at-desk + Stripe checkout persistence) ──────

model Order {
  id              String    @id @default(cuid())
  tenantId        String
  memberId        String?
  member          Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  orderRef        String    @unique // human-friendly reference shown on receipts (e.g. ORD-LMRK4G)
  items           Json // snapshot of cart at order time: [{id,name,price,quantity}]
  totalPence      Int
  currency        String    @default("GBP")
  status          String    @default("pending") // CHECK: pending | paid | cancelled (enforced by 20260430000005 migration)
  paymentMethod   String // CHECK: pay_at_desk | stripe (enforced by 20260430000005 migration)
  paidAt          DateTime?
  paidByUserId    String? // staff user who marked it paid (pay_at_desk only)
  stripeSessionId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([memberId])
}

// ─── Club Store Products (B9 — replaces static lib/products.ts) ─────────────

model Product {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  pricePence  Int
  currency    String    @default("GBP")
  category    String    @default("other") // CHECK: clothing | food | drink | equipment | other (enforced by 20260430000003 migration)
  symbol      String?
  description String?
  inStock     Boolean   @default(true)
  deletedAt   DateTime? // Soft-delete; consumers default-filter where deletedAt IS NULL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, deletedAt])
  @@index([tenantId, inStock, deletedAt])
}

// ─── Gym Applications (B10 — public /apply form persistence) ────────────────

model GymApplication {
  id          String   @id @default(cuid())
  gymName     String
  contactName String
  email       String
  phone       String?
  discipline  String
  memberCount String
  notes       String?
  status      String   @default("new") // CHECK: new | contacted | approved | rejected (enforced by 20260430000004 migration)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

// ─── Membership Tiers ────────────────────────────────────────────────────────

model MembershipTier {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  name              String
  description       String?
  pricePence        Int      @default(0)
  currency          String   @default("GBP")
  billingCycle      String   @default("monthly") // CHECK: monthly | annual | none (enforced by 20260430000001)
  maxClassesPerWeek Int?
  isKids            Boolean  @default(false)
  isActive          Boolean  @default(true)
  // Stripe linkage (matches ClassPack shape). Once a tier is wired to a
  // Stripe price, F2/F3 (member self-subscribe + parent-pays-for-kid) can
  // look up the picked price → tier server-side and enforce the kid/adult
  // gate. Both fields are nullable so existing tenants don't break.
  stripePriceId     String?
  stripeProductId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, isActive])
}

// ─── Super-admin (operator) identity ─────────────────────────────────────────
//
// v1 ships with a single shared `MATFLOW_ADMIN_SECRET` cookie — every action is
// stamped with the sentinel `__matflow_super_admin__`. This table is the
// foundation for v1.5 multi-operator (Noe, support staff, etc.) — each row is
// a real operator login with an individual audit trail. UI is deferred; ship
// the table now so v1.5 is purely additive.
model Operator {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String
  role             String    @default("super_admin") // super_admin | billing_admin | support_admin | read_only
  totpEnabled      Boolean   @default(false)
  totpSecret       String?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  sessionVersion   Int       @default(0)
  createdAt        DateTime  @default(now())
  lastLoginAt      DateTime?
}

// ─── Platform-level configuration (singleton-style key/value) ────────────────
//
// Holds platform-wide settings: audit-log retention days, feature-flag
// defaults, webhook outboxes (Slack / email destinations for operator alerts).
model PlatformConfig {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ─── Team tasks ─────────────────────────────────────────────────────────────
//
// User-authored to-do items that staff can assign to each other and complete.
// Renders alongside the auto-derived gym-health items (missing waivers, etc.)
// inside the dashboard's `{firstName}'s To Do List` panel. Activity feed
// powers the drawer's "History" tab.
//
// Status / action values are String to match the rest of the schema (see
// User.role precedent). CHECK constraints are enforced in the migration SQL,
// not via Prisma enums, to keep the existing migration style.

model Task {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Audit iter-1-database A8I1-V-2 [Critical]: nullable + onDelete: SetNull
  // so deleting the creator/assignee doesn't hit Prisma P2003 FK RESTRICT.
  // Same fix pattern as Area 6's AuditLog.userId + AttendanceRecord +
  // Class.coachUserId — Task was created AFTER that batch landed and was
  // missed.
  createdById  String?
  createdBy    User?   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  // feat/member-tickable-notes Phase 4: a Task can be addressed to a Member
  // INSTEAD OF a User. XOR enforced by Task_assignee_xor_check in migration
  // 20260601110000. When set, the Task is rendered on the member's action
  // list (app/member/actions) and the member ticks it themselves.
  assigneeMemberId String?
  assigneeMember   Member? @relation("TaskAssigneeMember", fields: [assigneeMemberId], references: [id], onDelete: SetNull)

  // Optional long-form content. Required when kind='member_note' (members
  // need context — a 140-char title alone is too thin for "renew waiver
  // because of new insurance terms"). NULL for staff_task (staff title-only).
  body String? @db.VarChar(1000)

  // CHECK: staff_task | member_note (enforced by 20260601110000 migration).
  // Determines which assignee column is required and whether body is required.
  kind String @default("staff_task")

  // Who ticked the box. Always a User — for member-completions the route
  // resolves the member's matching User row (or leaves NULL if member has
  // no User, e.g. magic-link-only kids profile).
  completedById String?
  completedBy   User?   @relation("TaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  title       String    @db.VarChar(140)
  status      String    @default("open") // CHECK: open | done (enforced by migration)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([tenantId, status, assignedToId])
  // Audit iter-2 M2-1: declare the createdById index so schema matches DB.
  // The index itself ships in migration 20260530201740_task_rls_and_createdby_index.
  @@index([tenantId, status, createdById])
  @@index([tenantId, createdAt])
  // feat/member-tickable-notes Phase 4: member-side fetch path —
  // GET /api/member/tasks filters by (tenantId, assigneeMemberId, status='open').
  @@index([tenantId, status, assigneeMemberId])
}
